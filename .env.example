# =============================================================================
# The Estate Edit — Payload CMS (estate-edit-cms)
# Copy to .env and fill in. This app shares the SAME Supabase project as the
# public site (project ref: czvrsproxqlpcnvbaltq).
# =============================================================================

# --- Payload core ------------------------------------------------------------
# Long random string. Generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace-with-a-long-random-secret

# Public URL where this CMS is reachable (used for admin + media links/CORS).
# Local: http://localhost:3000   Prod: https://cms.your-domain.com
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Comma-separated list of origins allowed to call the API / be CSRF-trusted.
# Include the public marketing site so it (or you) can fetch the REST API.
PAYLOAD_PUBLIC_ALLOWED_ORIGINS=http://localhost:3000,https://estate-edit.joatkenya120.workers.dev

# --- Database (Supabase Postgres) -------------------------------------------
# Use the Supabase CONNECTION POOLER URI (Dashboard > Database > Connect).
# For Vercel serverless prefer the TRANSACTION pooler (port 6543).
# Example: postgresql://postgres.czvrsproxqlpcnvbaltq:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URI=postgresql://postgres.czvrsproxqlpcnvbaltq:<password>@<host>.pooler.supabase.com:6543/postgres

# --- Media storage (Supabase S3-compatible) ---------------------------------
# Supabase Dashboard > Storage > S3 Connection / Access Keys.
SUPABASE_S3_ENDPOINT=https://czvrsproxqlpcnvbaltq.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=eu-central-1
SUPABASE_S3_ACCESS_KEY_ID=replace-with-supabase-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=replace-with-supabase-s3-secret
SUPABASE_S3_BUCKET=asset-images

# Public base URL used to build CDN links stored on assets (matches the
# public bucket already whitelisted in the site's next.config.ts).
# {SUPABASE_PUBLIC_URL}/storage/v1/object/public/{bucket}/{prefix}/{filename}
SUPABASE_PUBLIC_URL=https://czvrsproxqlpcnvbaltq.supabase.co
